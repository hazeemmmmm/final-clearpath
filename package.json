{
  "name": "clearpath-monorepo",
  "version": "1.0.0",
  "description": "Root package to run backend and frontend concurrently",
  "scripts": {
    "backend": "npm run start:dev --prefix Backend",
    "frontend": "npm run dev --prefix frontend",
    "dev": "concurrently -n \"Backend,Frontend\" -c \"bgBlue,bgGreen\" \"npm run backend\" \"npm run frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
